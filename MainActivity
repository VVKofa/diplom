package com.example.directionprogramm

import android.content.Intent
import android.os.Bundle
import android.widget.Button
import android.widget.EditText
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import androidx.lifecycle.lifecycleScope
import kotlinx.coroutines.launch

class MainActivity : AppCompatActivity() {

    private lateinit var loginInput: EditText
    private lateinit var passwordInput: EditText
    private lateinit var loginButton: Button
    private lateinit var sessionManager: SessionManager
    private lateinit var db: AppDatabase

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        sessionManager = SessionManager(this)
        db = AppDatabase.getDatabase(this)

        loginInput = findViewById(R.id.loginInput)
        passwordInput = findViewById(R.id.passwordInput)
        loginButton = findViewById(R.id.loginButton)

        lifecycleScope.launch {
            prepareDemoData()

            if (sessionManager.isLoggedIn()) {
                openScreenByRole(sessionManager.getUserRole())
                finish()
                return@launch
            }

            loginButton.setOnClickListener {
                login()
            }
        }
    }

    private suspend fun prepareDemoData() {
        val users = db.userDao().getAllUsers()
        val carWashes = db.carWashDao().getAllCarWashes()

        if (users.isEmpty() || carWashes.isEmpty()) {
            DemoDataSeeder(db).seedCarWashesAndUsers()
        }
    }

    private fun login() {
        val login = loginInput.text.toString().trim()
        val password = passwordInput.text.toString().trim()

        if (login.isEmpty() || password.isEmpty()) {
            Toast.makeText(this, "Введите логин и пароль", Toast.LENGTH_SHORT).show()
            return
        }

        lifecycleScope.launch {
            val user = db.userDao().getUserByLoginAndPassword(login, password)

            if (user == null) {
                Toast.makeText(
                    this@MainActivity,
                    "Неверный логин или пароль",
                    Toast.LENGTH_SHORT
                ).show()
                return@launch
            }

            if (!user.isActive) {
                Toast.makeText(
                    this@MainActivity,
                    "Аккаунт неактивен. Обратитесь к руководителю",
                    Toast.LENGTH_SHORT
                ).show()
                return@launch
            }

            sessionManager.saveUser(user)
            openScreenByRole(user.role)
            finish()
        }
    }

    private fun openScreenByRole(role: String?) {
        when (role) {
            "admin" -> startActivity(Intent(this, AdminActivity::class.java))
            "manager" -> startActivity(Intent(this, ManagerActivity::class.java))
            "director" -> startActivity(Intent(this, DirectorActivity::class.java))
            else -> Toast.makeText(this, "Неизвестная роль пользователя", Toast.LENGTH_SHORT).show()
        }
    }
}
