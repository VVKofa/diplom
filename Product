package com.example.directionprogramm

import androidx.room.Entity
import androidx.room.Index
import androidx.room.PrimaryKey

@Entity(
    tableName = "products",
    indices = [
        Index(value = ["name"], unique = true)
    ]
)
data class Product(
    val name: String,

    @PrimaryKey(autoGenerate = true)
    val id: Int = 0
)
