<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F6F8">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Верхний красивый блок -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:background="@drawable/bg_accounts_header">

                <ImageView
                    android:id="@+id/backButton"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_small_white_circle"
                    android:contentDescription="Назад"
                    android:elevation="6dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_back_blue" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_marginStart="28dp"
                    android:layout_marginEnd="28dp"
                    android:layout_marginBottom="38dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_header_icon_circle"
                        android:elevation="8dp">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:contentDescription="Аккаунты"
                            android:src="@drawable/ic_accounts_group"
                            app:tint="#2F8DE4" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="22dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Аккаунты"
                            android:textColor="#1F2937"
                            android:textSize="34sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Управление пользователями системы"
                            android:textColor="#6B7280"
                            android:textSize="16sp" />

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- Контент -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-18dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:orientation="vertical">

                <!-- Карточка территориальных менеджеров -->
                <LinearLayout
                    android:id="@+id/managersCard"
                    android:layout_width="match_parent"
                    android:layout_height="128dp"
                    android:background="@drawable/bg_accounts_card"
                    android:clickable="true"
                    android:elevation="6dp"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="22dp"
                    android:paddingEnd="18dp">

                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_card_icon_blue_green">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:contentDescription="Территориальные менеджеры"
                            android:src="@drawable/ic_location_manager"
                            app:tint="#FFFFFF" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Территориальные менеджеры"
                            android:textColor="#1F2937"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:text="Просмотр и управление"
                            android:textColor="#6B7280"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="Перейти"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="#2F8DE4" />

                </LinearLayout>

                <!-- Карточка администраторов -->
                <LinearLayout
                    android:id="@+id/adminsCard"
                    android:layout_width="match_parent"
                    android:layout_height="128dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_accounts_card"
                    android:clickable="true"
                    android:elevation="6dp"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="22dp"
                    android:paddingEnd="18dp">

                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_card_icon_blue">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:contentDescription="Администраторы"
                            android:src="@drawable/ic_admin_shield"
                            app:tint="#FFFFFF" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Администраторы"
                            android:textColor="#1F2937"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:text="Просмотр и управление"
                            android:textColor="#6B7280"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="Перейти"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="#2F8DE4" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>
