package com.example.directionprogramm

import android.app.AlertDialog
import android.graphics.Color
import android.os.Bundle
import android.view.Gravity
import android.view.View
import android.view.ViewGroup
import android.widget.Button
import android.widget.EditText
import android.widget.ImageButton
import android.widget.LinearLayout
import android.widget.TextView
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import androidx.cardview.widget.CardView
import androidx.recyclerview.widget.ItemTouchHelper
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView

class DirectorProductsActivity : AppCompatActivity() {

    private lateinit var backButton: ImageButton
    private lateinit var addProductButton: Button
    private lateinit var productsRecycler: RecyclerView
    private lateinit var emptyText: TextView

    private lateinit var productRepository: ProductRepository
    private lateinit var adapter: DirectorProductsAdapter

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_director_products)

        productRepository = ProductRepository(this)

        backButton = findViewById(R.id.backButtonDirectorProducts)
        addProductButton = findViewById(R.id.addProductButton)
        productsRecycler = findViewById(R.id.directorProductsRecycler)
        emptyText = findViewById(R.id.emptyDirectorProductsText)

        backButton.setOnClickListener {
            finish()
        }

        addProductButton.setOnClickListener {
            showProductDialog(null)
        }

        adapter = DirectorProductsAdapter(
            onEdit = { product ->
                showProductDialog(product)
            }
        )

        productsRecycler.layoutManager = LinearLayoutManager(this)
        productsRecycler.adapter = adapter

        setupSwipeToDelete()
        loadProducts()
    }

    private fun loadProducts() {
        val products = productRepository.getProducts()

        if (products.isEmpty()) {
            emptyText.visibility = View.VISIBLE
            productsRecycler.visibility = View.GONE
        } else {
            emptyText.visibility = View.GONE
            productsRecycler.visibility = View.VISIBLE
            adapter.submitList(products)
        }
    }

    private fun showProductDialog(product: Product?) {
        val input = EditText(this).apply {
            hint = "Название товара"
            setText(product?.name ?: "")
            setPadding(32, 20, 32, 20)
            setSelection(text.length)
        }

        AlertDialog.Builder(this)
            .setTitle(if (product == null) "Добавить товар" else "Редактировать товар")
            .setView(input)
            .setPositiveButton(if (product == null) "Добавить" else "Сохранить") { _, _ ->
                val name = input.text.toString().trim()

                if (name.isEmpty()) {
                    Toast.makeText(this, "Введите название товара", Toast.LENGTH_SHORT).show()
                    return@setPositiveButton
                }

                if (product == null) {
                    val success = productRepository.addProduct(name)

                    if (success) {
                        Toast.makeText(this, "Товар добавлен", Toast.LENGTH_SHORT).show()
                    } else {
                        Toast.makeText(this, "Такой товар уже существует", Toast.LENGTH_SHORT).show()
                        return@setPositiveButton
                    }
                } else {
                    val success = productRepository.updateProduct(product.name, name)

                    if (success) {
                        Toast.makeText(this, "Товар изменён", Toast.LENGTH_SHORT).show()
                    } else {
                        Toast.makeText(this, "Такой товар уже существует", Toast.LENGTH_SHORT).show()
                        return@setPositiveButton
                    }
                }

                loadProducts()
            }
            .setNegativeButton("Отмена", null)
            .show()
    }

    private fun confirmDelete(product: Product, restorePosition: Int? = null) {
        AlertDialog.Builder(this)
            .setTitle("Удалить товар?")
            .setMessage(product.name)
            .setPositiveButton("Удалить") { _, _ ->
                productRepository.deleteProduct(product.name)
                Toast.makeText(this, "Товар удалён", Toast.LENGTH_SHORT).show()
                loadProducts()
            }
            .setNegativeButton("Отмена") { _, _ ->
                restorePosition?.let { adapter.notifyItemChanged(it) }
            }
            .setOnCancelListener {
                restorePosition?.let { adapter.notifyItemChanged(it) }
            }
            .show()
    }

    private fun setupSwipeToDelete() {
        val itemTouchHelper = ItemTouchHelper(
            object : ItemTouchHelper.SimpleCallback(0, ItemTouchHelper.LEFT) {

                override fun onMove(
                    recyclerView: RecyclerView,
                    viewHolder: RecyclerView.ViewHolder,
                    target: RecyclerView.ViewHolder
                ): Boolean = false

                override fun onSwiped(viewHolder: RecyclerView.ViewHolder, direction: Int) {
                    val position = viewHolder.bindingAdapterPosition

                    if (position == RecyclerView.NO_POSITION) {
                        return
                    }

                    val product = adapter.getProductAt(position)
                    confirmDelete(product, position)
                }
            }
        )

        itemTouchHelper.attachToRecyclerView(productsRecycler)
    }

    inner class DirectorProductsAdapter(
        private val onEdit: (Product) -> Unit
    ) : RecyclerView.Adapter<DirectorProductsAdapter.ProductViewHolder>() {

        private val items = mutableListOf<Product>()

        fun submitList(newItems: List<Product>) {
            items.clear()
            items.addAll(newItems)
            notifyDataSetChanged()
        }

        fun getProductAt(position: Int): Product {
            return items[position]
        }

        override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ProductViewHolder {
            val card = CardView(parent.context).apply {
                radius = 22f
                cardElevation = 6f
                useCompatPadding = true
                setCardBackgroundColor(Color.WHITE)

                layoutParams = RecyclerView.LayoutParams(
                    RecyclerView.LayoutParams.MATCH_PARENT,
                    RecyclerView.LayoutParams.WRAP_CONTENT
                ).apply {
                    leftMargin = 12
                    rightMargin = 12
                    topMargin = 8
                    bottomMargin = 8
                }
            }

            val container = LinearLayout(parent.context).apply {
                orientation = LinearLayout.HORIZONTAL
                gravity = Gravity.CENTER_VERTICAL
                setPadding(28, 24, 28, 24)
            }

            val title = TextView(parent.context).apply {
                textSize = 18f
                setTextColor(Color.parseColor("#1F2937"))
                setTypeface(typeface, android.graphics.Typeface.BOLD)

                layoutParams = LinearLayout.LayoutParams(
                    0,
                    LinearLayout.LayoutParams.WRAP_CONTENT,
                    1f
                )
            }

            val buttonsContainer = LinearLayout(parent.context).apply {
                orientation = LinearLayout.HORIZONTAL
                gravity = Gravity.CENTER_VERTICAL
            }

            val editButton = ImageButton(parent.context).apply {
                setImageResource(R.drawable.ic_edit)
                background = parent.context.getDrawable(R.drawable.circle_button_bg)
                setPadding(20, 20, 20, 20)
                contentDescription = "Редактировать"

                layoutParams = LinearLayout.LayoutParams(96, 96).apply {
                    rightMargin = 12
                }
            }

            val deleteButton = ImageButton(parent.context).apply {
                setImageResource(R.drawable.ic_delete)
                background = parent.context.getDrawable(R.drawable.circle_button_bg)
                setPadding(20, 20, 20, 20)
                contentDescription = "Удалить"

                layoutParams = LinearLayout.LayoutParams(96, 96)
            }

            buttonsContainer.addView(editButton)
            buttonsContainer.addView(deleteButton)

            container.addView(title)
            container.addView(buttonsContainer)

            card.addView(container)

            return ProductViewHolder(card, title, editButton, deleteButton)
        }

        override fun onBindViewHolder(holder: ProductViewHolder, position: Int) {
            val product = items[position]

            holder.title.text = product.name

            holder.editButton.setOnClickListener {
                onEdit(product)
            }

            holder.deleteButton.setOnClickListener {
                confirmDelete(product)
            }
        }

        override fun getItemCount(): Int = items.size

        inner class ProductViewHolder(
            itemView: View,
            val title: TextView,
            val editButton: ImageButton,
            val deleteButton: ImageButton
        ) : RecyclerView.ViewHolder(itemView)
    }
}
