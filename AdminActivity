package com.example.directionprogramm

import android.content.Intent
import android.graphics.Color
import android.os.Bundle
import android.view.View
import android.view.ViewGroup
import android.widget.Button
import android.widget.FrameLayout
import android.widget.LinearLayout
import android.widget.TextView
import androidx.appcompat.app.AppCompatActivity
import androidx.cardview.widget.CardView
import androidx.lifecycle.lifecycleScope
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import kotlinx.coroutines.launch

class AdminActivity : AppCompatActivity() {

    private lateinit var requestRepository: RequestRepository
    private lateinit var notificationRepository: NotificationRepository
    private lateinit var sessionManager: SessionManager

    private lateinit var notificationContainer: FrameLayout
    private lateinit var notificationBadge: TextView
    private lateinit var notificationLayout: LinearLayout
    private lateinit var notificationText: TextView

    private lateinit var cartCountBadge: TextView
    private lateinit var lastOrdersRecycler: RecyclerView

    private lateinit var catalogCard: LinearLayout
    private lateinit var cartCard: LinearLayout
    private lateinit var historyCard: LinearLayout
    private lateinit var profileCard: LinearLayout
    private lateinit var stocksCard: LinearLayout

    private lateinit var viewAllOrdersText: TextView
    private lateinit var logoutButtonAdmin: Button

    private lateinit var requestsAdapter: AdminLastRequestsAdapter

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_admin)

        requestRepository = RequestRepository(this)
        notificationRepository = NotificationRepository(this)
        sessionManager = SessionManager(this)

        initViews()
        setupClicks()
        setupLastRequests()
        loadAdminNotifications()
        updateCartBadge()
    }

    override fun onResume() {
        super.onResume()
        loadAdminNotifications()
        loadLastRequests()
        updateCartBadge()
    }

    private fun initViews() {
        notificationContainer = findViewById(R.id.notificationContainer)
        notificationBadge = findViewById(R.id.notificationBadge)
        notificationLayout = findViewById(R.id.notificationLayout)
        notificationText = findViewById(R.id.notificationText)

        cartCountBadge = findViewById(R.id.cartCountBadge)
        lastOrdersRecycler = findViewById(R.id.lastOrdersRecycler)

        catalogCard = findViewById(R.id.catalogCard)
        cartCard = findViewById(R.id.cartCard)
        historyCard = findViewById(R.id.historyCard)
        profileCard = findViewById(R.id.profileCard)
        stocksCard = findViewById(R.id.stocksCardAdmin)

        viewAllOrdersText = findViewById(R.id.viewAllOrdersText)
        logoutButtonAdmin = findViewById(R.id.logoutButtonAdmin)
    }

    private fun setupClicks() {
        notificationContainer.setOnClickListener {
            if (notificationLayout.visibility == View.VISIBLE) {
                notificationLayout.visibility = View.GONE
            } else {
                notificationLayout.visibility = View.VISIBLE
                showAllAdminNotifications()
            }
        }

        catalogCard.setOnClickListener {
            startActivity(Intent(this, ProductsActivity::class.java))
        }

        cartCard.setOnClickListener {
            startActivity(Intent(this, CartActivity::class.java))
        }

        historyCard.setOnClickListener {
            startActivity(Intent(this, AdminOrderHistoryActivity::class.java))
        }

        profileCard.setOnClickListener {
            startActivity(Intent(this, ProfileActivity::class.java))
        }

        stocksCard.setOnClickListener {
            startActivity(Intent(this, AdminStocksActivity::class.java))
        }

        viewAllOrdersText.setOnClickListener {
            startActivity(Intent(this, AdminOrderHistoryActivity::class.java))
        }

        logoutButtonAdmin.setOnClickListener {
            sessionManager.logout()

            val intent = Intent(this, MainActivity::class.java)
            intent.flags = Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK
            startActivity(intent)

            finish()
        }
    }

    private fun setupLastRequests() {
        requestsAdapter = AdminLastRequestsAdapter { request ->
            val intent = Intent(this, ManagerRequestDetailsActivity::class.java)
            intent.putExtra("request_id", request.id)
            startActivity(intent)
        }

        lastOrdersRecycler.layoutManager = LinearLayoutManager(this)
        lastOrdersRecycler.adapter = requestsAdapter

        loadLastRequests()
    }

    private fun loadLastRequests() {
        val carWashId = sessionManager.getCarWashId()

        if (carWashId == null) {
            requestsAdapter.submitList(emptyList())
            return
        }

        val requests = requestRepository.getAdminRequests()
            .filter { it.carWashId == carWashId }
            .sortedByDescending { it.id }
            .take(3)

        requestsAdapter.submitList(requests)
    }

    private fun loadAdminNotifications() {
        lifecycleScope.launch {
            val carWashId = sessionManager.getCarWashId()

            if (carWashId == null) {
                notificationBadge.visibility = View.GONE
                notificationText.text = "Администратор не закреплен за автомойкой"
                return@launch
            }

            val unreadCount = notificationRepository.getAdminUnreadCount(carWashId)

            if (unreadCount > 0) {
                notificationBadge.visibility = View.VISIBLE
                notificationBadge.text = unreadCount.toString()
            } else {
                notificationBadge.visibility = View.GONE
            }

            val notifications = notificationRepository.getAdminNotifications(carWashId)

            if (notifications.isEmpty()) {
                notificationText.text = "Уведомлений нет"
                notificationText.setOnClickListener(null)
            } else {
                val latest = notifications.first()

                notificationText.text = "• ${latest.title}\n${latest.message}"
                notificationText.isClickable = true
                notificationText.isFocusable = true

                notificationText.setOnClickListener {
                    lifecycleScope.launch {
                        notificationRepository.markAsRead(latest.id)
                        notificationLayout.visibility = View.GONE
                        loadAdminNotifications()
                        openAdminNotification(latest)
                    }
                }
            }
        }
    }

    private fun openAdminNotification(notification: NotificationEntity) {
        when {
            notification.orderId != null -> {
                val intent = Intent(this, OrderDetailsActivity::class.java)
                intent.putExtra("order_id", notification.orderId)
                startActivity(intent)
            }

            notification.requestId != null -> {
                startActivity(Intent(this, AdminOrderHistoryActivity::class.java))
            }

            else -> {
                startActivity(Intent(this, AdminOrderHistoryActivity::class.java))
            }
        }
    }

    private fun showAllAdminNotifications() {
        lifecycleScope.launch {
            val carWashId = sessionManager.getCarWashId()

            if (carWashId == null) {
                notificationText.text = "Администратор не закреплен за автомойкой"
                notificationBadge.visibility = View.GONE
                notificationText.setOnClickListener(null)
                return@launch
            }

            val notifications = notificationRepository.getAdminNotifications(carWashId)

            if (notifications.isEmpty()) {
                notificationText.text = "Уведомлений нет"
                notificationText.setOnClickListener(null)
                notificationBadge.visibility = View.GONE
                return@launch
            }

            notificationText.text = notifications.joinToString("\n\n") {
                "• ${it.title}\n${it.message}"
            }

            val latestNotification = notifications.first()

            notificationText.isClickable = true
            notificationText.isFocusable = true
            notificationText.setOnClickListener {
                lifecycleScope.launch {
                    notificationRepository.markAsRead(latestNotification.id)
                    notificationLayout.visibility = View.GONE
                    loadAdminNotifications()
                    openAdminNotification(latestNotification)
                }
            }
        }
    }

    private fun updateCartBadge() {
        cartCountBadge.visibility = View.GONE
    }

    inner class AdminLastRequestsAdapter(
        private val onItemClick: (RequestModel) -> Unit
    ) : RecyclerView.Adapter<AdminLastRequestsAdapter.RequestViewHolder>() {

        private val requests = mutableListOf<RequestModel>()

        fun submitList(newRequests: List<RequestModel>) {
            requests.clear()
            requests.addAll(newRequests)
            notifyDataSetChanged()
        }

        override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): RequestViewHolder {
            val cardView = CardView(parent.context).apply {
                radius = 22f
                cardElevation = 6f
                useCompatPadding = true
                setCardBackgroundColor(Color.WHITE)

                layoutParams = RecyclerView.LayoutParams(
                    RecyclerView.LayoutParams.MATCH_PARENT,
                    RecyclerView.LayoutParams.WRAP_CONTENT
                ).apply {
                    bottomMargin = 24
                }
            }

            val container = LinearLayout(parent.context).apply {
                orientation = LinearLayout.VERTICAL
                setPadding(32, 28, 32, 28)
            }

            val title = TextView(parent.context).apply {
                textSize = 20f
                setTextColor(Color.parseColor("#1F2937"))
                setTypeface(typeface, android.graphics.Typeface.BOLD)
            }

            val date = TextView(parent.context).apply {
                textSize = 15f
                setTextColor(Color.parseColor("#374151"))
                setPadding(0, 12, 0, 0)
            }

            val count = TextView(parent.context).apply {
                textSize = 15f
                setTextColor(Color.parseColor("#374151"))
                setPadding(0, 6, 0, 0)
            }

            val status = TextView(parent.context).apply {
                textSize = 15f
                setTypeface(typeface, android.graphics.Typeface.BOLD)
                setPadding(0, 8, 0, 0)
            }

            container.addView(title)
            container.addView(date)
            container.addView(count)
            container.addView(status)
            cardView.addView(container)

            return RequestViewHolder(cardView, title, date, count, status)
        }

        override fun onBindViewHolder(holder: RequestViewHolder, position: Int) {
            val request = requests[position]

            holder.title.text = "Заявка №${request.id}"
            holder.date.text = "Дата создания: ${request.createdDate}"
            holder.count.text = "Товаров: ${request.items.sumOf { it.quantity }}"
            holder.status.text = "Статус: ${request.status}"

            holder.status.setTextColor(
                when (request.status) {
                    "Новая" -> Color.parseColor("#10B981")
                    "Обработана" -> Color.parseColor("#2563EB")
                    "Отклонена" -> Color.parseColor("#EF4444")
                    else -> Color.parseColor("#374151")
                }
            )

            holder.itemView.setOnClickListener {
                onItemClick(request)
            }
        }

        override fun getItemCount(): Int = requests.size

        inner class RequestViewHolder(
            itemView: View,
            val title: TextView,
            val date: TextView,
            val count: TextView,
            val status: TextView
        ) : RecyclerView.ViewHolder(itemView)
    }
}
