<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:paddingTop="48dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/blue_gradient"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <ImageButton
            android:id="@+id/backButtonManagerRequests"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/white"
            android:contentDescription="Назад" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Заявки администраторов"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:layout_marginStart="12dp"
            android:textStyle="bold"/>
    </LinearLayout>

    <Button
        android:id="@+id/createCombinedOrderButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/button_background_blue"
        android:text="Сформировать общий заказ"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:enabled="false"
        android:alpha="0.5" />

    <TextView
        android:id="@+id/emptyTextManagerRequests"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нет заявок"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/requestsRecycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="12dp"/>

</LinearLayout>
