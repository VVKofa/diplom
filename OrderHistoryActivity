package com.example.directionprogramm

import android.content.Intent
import android.graphics.Color
import android.os.Bundle
import android.view.View
import android.view.ViewGroup
import android.widget.ImageButton
import android.widget.LinearLayout
import android.widget.TextView
import androidx.appcompat.app.AppCompatActivity
import androidx.cardview.widget.CardView
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView

class OrderHistoryActivity : AppCompatActivity() {

    private lateinit var ordersRecycler: RecyclerView
    private lateinit var emptyText: TextView
    private lateinit var backButton: ImageButton
    private lateinit var orderRepository: OrderRepository
    private lateinit var adapter: HistoryAdapter

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_order_history)

        orderRepository = OrderRepository(this)

        ordersRecycler = findViewById(R.id.ordersRecycler)
        emptyText = findViewById(R.id.emptyText)
        backButton = findViewById(R.id.backButtonOrderHistory)

        backButton.setOnClickListener {
            finish()
        }

        ordersRecycler.layoutManager = LinearLayoutManager(this)

        adapter = HistoryAdapter { order ->
            val intent = Intent(this, OrderDetailsActivity::class.java)
            intent.putExtra("order_id", order.id)
            startActivity(intent)
        }

        ordersRecycler.adapter = adapter

        loadOrders()
    }

    override fun onResume() {
        super.onResume()
        loadOrders()
    }

    private fun loadOrders() {
        val orders = orderRepository.getAllOrders()
            .sortedByDescending { it.id }

        if (orders.isEmpty()) {
            emptyText.visibility = View.VISIBLE
            ordersRecycler.visibility = View.GONE
        } else {
            emptyText.visibility = View.GONE
            ordersRecycler.visibility = View.VISIBLE
            adapter.submitList(orders)
        }
    }

    inner class HistoryAdapter(
        private val onClick: (OrderModel) -> Unit
    ) : RecyclerView.Adapter<HistoryAdapter.Holder>() {

        private val items = mutableListOf<OrderModel>()

        fun submitList(newItems: List<OrderModel>) {
            items.clear()
            items.addAll(newItems)
            notifyDataSetChanged()
        }

        override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): Holder {
            val card = CardView(parent.context).apply {
                radius = 28f
                cardElevation = 5f
                useCompatPadding = true
                setCardBackgroundColor(Color.WHITE)

                layoutParams = RecyclerView.LayoutParams(
                    RecyclerView.LayoutParams.MATCH_PARENT,
                    RecyclerView.LayoutParams.WRAP_CONTENT
                ).apply {
                    leftMargin = 6
                    rightMargin = 6
                    topMargin = 8
                    bottomMargin = 8
                }
            }

            val container = LinearLayout(parent.context).apply {
                orientation = LinearLayout.VERTICAL
                setPadding(30, 26, 30, 26)
            }

            val title = TextView(parent.context).apply {
                textSize = 18f
                setTextColor(Color.parseColor("#1F2937"))
                setTypeface(typeface, android.graphics.Typeface.BOLD)
            }

            val date = TextView(parent.context).apply {
                textSize = 15f
                setTextColor(Color.parseColor("#6B7280"))
                setPadding(0, 10, 0, 0)
            }

            val status = TextView(parent.context).apply {
                textSize = 15f
                setTextColor(Color.parseColor("#007BFF"))
                setPadding(0, 8, 0, 0)
                setTypeface(typeface, android.graphics.Typeface.BOLD)
            }

            val count = TextView(parent.context).apply {
                textSize = 14f
                setTextColor(Color.parseColor("#374151"))
                setPadding(0, 8, 0, 0)
            }

            container.addView(title)
            container.addView(date)
            container.addView(status)
            container.addView(count)

            card.addView(container)

            return Holder(card, title, date, status, count)
        }

        override fun onBindViewHolder(holder: Holder, position: Int) {
            val item = items[position]

            holder.title.text = "Заказ №${item.id}"
            holder.date.text = "Дата создания: ${item.createdDate}"
            holder.status.text = "Статус: ${item.status}"
            holder.count.text = "Количество товаров: ${item.items.sumOf { it.quantity }}"

            holder.itemView.setOnClickListener {
                onClick(item)
            }
        }

        override fun getItemCount(): Int = items.size

        inner class Holder(
            itemView: View,
            val title: TextView,
            val date: TextView,
            val status: TextView,
            val count: TextView
        ) : RecyclerView.ViewHolder(itemView)
    }
}
