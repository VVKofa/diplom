package com.example.directionprogramm

import android.content.Intent
import android.graphics.Color
import android.os.Bundle
import android.view.View
import android.view.ViewGroup
import android.widget.Button
import android.widget.FrameLayout
import android.widget.LinearLayout
import android.widget.TextView
import androidx.appcompat.app.AppCompatActivity
import androidx.cardview.widget.CardView
import androidx.lifecycle.lifecycleScope
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import kotlinx.coroutines.launch

class ManagerActivity : AppCompatActivity() {

    private lateinit var sessionManager: SessionManager
    private lateinit var requestRepository: RequestRepository
    private lateinit var notificationRepository: NotificationRepository
    private lateinit var db: AppDatabase

    private lateinit var notificationContainer: FrameLayout
    private lateinit var notificationBadge: TextView
    private lateinit var notificationLayout: LinearLayout

    private lateinit var userNameText: TextView
    private lateinit var helloText: TextView

    private lateinit var carWashCard: LinearLayout
    private lateinit var requestsCard: LinearLayout
    private lateinit var historyCard: LinearLayout
    private lateinit var profileCard: LinearLayout
    private lateinit var requestChartCard: LinearLayout
    private lateinit var stocksCard: LinearLayout

    private lateinit var viewAllRequestsText: TextView
    private lateinit var lastRequestsRecycler: RecyclerView
    private lateinit var logoutButton: Button

    private lateinit var lastRequestsAdapter: ManagerLastRequestsAdapter

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_manager)

        sessionManager = SessionManager(this)
        requestRepository = RequestRepository(this)
        notificationRepository = NotificationRepository(this)
        db = AppDatabase.getDatabase(this)

        initViews()
        setupUserInfo()
        setupClicks()
        setupLastRequests()
        loadManagerNotifications()
    }

    override fun onResume() {
        super.onResume()
        loadManagerNotifications()
        loadLastRequests()
    }

    private fun initViews() {
        notificationContainer = findViewById(R.id.notificationContainerManager)
        notificationBadge = findViewById(R.id.notificationBadgeManager)
        notificationLayout = findViewById(R.id.notificationLayoutManager)

        userNameText = findViewById(R.id.userNameTextManager)
        helloText = findViewById(R.id.helloTextManager)

        carWashCard = findViewById(R.id.carWashCardManager)
        requestsCard = findViewById(R.id.requestsCardManager)
        historyCard = findViewById(R.id.historyCardManager)
        profileCard = findViewById(R.id.profileCardManager)
        requestChartCard = findViewById(R.id.requestChartCardManager)
        stocksCard = findViewById(R.id.stocksCardManager)

        viewAllRequestsText = findViewById(R.id.viewAllRequestsTextManager)
        lastRequestsRecycler = findViewById(R.id.lastRequestsRecyclerManager)
        logoutButton = findViewById(R.id.logoutButtonManager)
    }

    private fun setupUserInfo() {
        val name = sessionManager.getUserName() ?: "Территориальный менеджер"

        userNameText.text = name
        helloText.text = "Здравствуйте, $name"
    }

    private fun setupClicks() {
        notificationContainer.setOnClickListener {
            if (notificationLayout.visibility == View.VISIBLE) {
                notificationLayout.visibility = View.GONE
            } else {
                notificationLayout.visibility = View.VISIBLE
                showManagerNotifications()
            }
        }

        carWashCard.setOnClickListener {
            startActivity(Intent(this, ManagerCarWashOrdersDistrictsActivity::class.java))
        }

        requestsCard.setOnClickListener {
            startActivity(Intent(this, ManagerRequestsActivity::class.java))
        }

        historyCard.setOnClickListener {
            startActivity(Intent(this, ManagerHistoryMenuActivity::class.java))
        }

        profileCard.setOnClickListener {
            startActivity(Intent(this, ProfileActivity::class.java))
        }

        requestChartCard.setOnClickListener {
            startActivity(Intent(this, ManagerRequestsChartActivity::class.java))
        }

        stocksCard.setOnClickListener {
            startActivity(Intent(this, ManagerStocksActivity::class.java))
        }

        viewAllRequestsText.setOnClickListener {
            startActivity(Intent(this, ManagerRequestsActivity::class.java))
        }

        logoutButton.setOnClickListener {
            sessionManager.logout()

            val intent = Intent(this, MainActivity::class.java)
            intent.flags = Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK
            startActivity(intent)

            finish()
        }
    }

    private fun setupLastRequests() {
        lastRequestsAdapter = ManagerLastRequestsAdapter { request ->
            val intent = Intent(this, ManagerRequestDetailsActivity::class.java)
            intent.putExtra("request_id", request.id)
            startActivity(intent)
        }

        lastRequestsRecycler.layoutManager = LinearLayoutManager(this)
        lastRequestsRecycler.adapter = lastRequestsAdapter

        loadLastRequests()
    }

    private fun loadLastRequests() {
        lifecycleScope.launch {
            val managerName = sessionManager.getUserName()

            if (managerName.isNullOrBlank()) {
                lastRequestsAdapter.submitList(emptyList())
                return@launch
            }

            val managerCarWashes = db.carWashDao().getCarWashesByManager(managerName)
            val managerCarWashIds = managerCarWashes.map { it.id }

            if (managerCarWashIds.isEmpty()) {
                lastRequestsAdapter.submitList(emptyList())
                return@launch
            }

            val requests = requestRepository.getAdminRequests()
                .filter { request ->
                    request.status != "Обработана" &&
                            managerCarWashIds.contains(request.carWashId)
                }
                .sortedByDescending { it.id }
                .take(3)

            lastRequestsAdapter.submitList(requests)
        }
    }

    private fun loadManagerNotifications() {
        lifecycleScope.launch {
            val managerName = sessionManager.getUserName()

            if (managerName.isNullOrBlank()) {
                notificationBadge.visibility = View.GONE
                return@launch
            }

            val unreadCount = notificationRepository.getManagerUnreadCount(managerName)

            if (unreadCount > 0) {
                notificationBadge.visibility = View.VISIBLE
                notificationBadge.text = unreadCount.toString()
            } else {
                notificationBadge.visibility = View.GONE
            }
        }
    }

    private fun openManagerNotification(notification: NotificationEntity) {
        when {
            notification.requestId != null -> {
                val intent = Intent(this, ManagerRequestDetailsActivity::class.java)
                intent.putExtra("request_id", notification.requestId)
                startActivity(intent)
            }

            notification.orderId != null -> {
                val intent = Intent(this, OrderDetailsActivity::class.java)
                intent.putExtra("order_id", notification.orderId)
                startActivity(intent)
            }

            else -> {
                startActivity(Intent(this, ManagerRequestsActivity::class.java))
            }
        }
    }

    private fun showManagerNotifications() {
        lifecycleScope.launch {
            val managerName = sessionManager.getUserName()

            notificationLayout.removeAllViews()

            if (managerName.isNullOrBlank()) {
                val emptyText = TextView(this@ManagerActivity).apply {
                    text = "Не удалось определить территориального менеджера"
                    textSize = 14f
                    setTextColor(Color.parseColor("#6B7280"))
                    setPadding(8, 8, 8, 8)
                }

                notificationLayout.addView(emptyText)
                notificationBadge.visibility = View.GONE
                return@launch
            }

            val notifications = notificationRepository.getManagerNotifications(managerName)

            if (notifications.isEmpty()) {
                val emptyText = TextView(this@ManagerActivity).apply {
                    text = "Уведомлений нет"
                    textSize = 14f
                    setTextColor(Color.parseColor("#6B7280"))
                    setPadding(8, 8, 8, 8)
                }

                notificationLayout.addView(emptyText)
                notificationBadge.visibility = View.GONE
                return@launch
            }

            notifications.forEach { notification ->
                val itemText = TextView(this@ManagerActivity).apply {
                    text = "• ${notification.title}\n${notification.message}"
                    textSize = 14f
                    setTextColor(Color.parseColor("#1F2937"))
                    setPadding(8, 8, 8, 14)
                    isClickable = true
                    isFocusable = true

                    setOnClickListener {
                        lifecycleScope.launch {
                            notificationRepository.markAsRead(notification.id)
                            notificationLayout.visibility = View.GONE
                            loadManagerNotifications()
                            openManagerNotification(notification)
                        }
                    }
                }

                notificationLayout.addView(itemText)
            }
        }
    }

    inner class ManagerLastRequestsAdapter(
        private val onItemClick: (RequestModel) -> Unit
    ) : RecyclerView.Adapter<ManagerLastRequestsAdapter.RequestViewHolder>() {

        private val requests = mutableListOf<RequestModel>()

        fun submitList(newRequests: List<RequestModel>) {
            requests.clear()
            requests.addAll(newRequests)
            notifyDataSetChanged()
        }

        override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): RequestViewHolder {
            val cardView = CardView(parent.context).apply {
                radius = 18f
                cardElevation = 4f
                useCompatPadding = true
                setCardBackgroundColor(Color.WHITE)

                layoutParams = RecyclerView.LayoutParams(
                    RecyclerView.LayoutParams.MATCH_PARENT,
                    RecyclerView.LayoutParams.WRAP_CONTENT
                ).apply {
                    bottomMargin = 16
                }
            }

            val container = LinearLayout(parent.context).apply {
                orientation = LinearLayout.VERTICAL
                setPadding(28, 22, 28, 22)
            }

            val title = TextView(parent.context).apply {
                textSize = 17f
                setTextColor(Color.parseColor("#1F2937"))
                setTypeface(typeface, android.graphics.Typeface.BOLD)
            }

            val date = TextView(parent.context).apply {
                textSize = 14f
                setTextColor(Color.parseColor("#374151"))
                setPadding(0, 8, 0, 0)
            }

            val count = TextView(parent.context).apply {
                textSize = 14f
                setTextColor(Color.parseColor("#374151"))
                setPadding(0, 5, 0, 0)
            }

            val status = TextView(parent.context).apply {
                textSize = 14f
                setTypeface(typeface, android.graphics.Typeface.BOLD)
                setPadding(0, 8, 0, 0)
            }

            container.addView(title)
            container.addView(date)
            container.addView(count)
            container.addView(status)

            cardView.addView(container)

            return RequestViewHolder(cardView, title, date, count, status)
        }

        override fun onBindViewHolder(holder: RequestViewHolder, position: Int) {
            val request = requests[position]

            holder.title.text = "Заявка №${request.id}"
            holder.date.text = "Дата создания: ${request.createdDate}"
            holder.count.text = "Товаров: ${request.items.sumOf { it.quantity }}"
            holder.status.text = "Статус: ${request.status}"

            holder.status.setTextColor(
                when (request.status) {
                    "Новая" -> Color.parseColor("#10B981")
                    "Обработана" -> Color.parseColor("#2563EB")
                    "Отклонена" -> Color.parseColor("#F59E0B")
                    else -> Color.parseColor("#374151")
                }
            )

            holder.itemView.setOnClickListener {
                onItemClick(request)
            }
        }

        override fun getItemCount(): Int = requests.size

        inner class RequestViewHolder(
            itemView: View,
            val title: TextView,
            val date: TextView,
            val count: TextView,
            val status: TextView
        ) : RecyclerView.ViewHolder(itemView)
    }
}
