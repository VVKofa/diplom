package com.example.directionprogramm

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView

class AssignmentAdapter : RecyclerView.Adapter<AssignmentAdapter.AssignmentViewHolder>() {

    private val items = mutableListOf<AdminAssignmentModel>()

    fun submitList(newItems: List<AdminAssignmentModel>) {
        items.clear()
        items.addAll(newItems)
        notifyDataSetChanged()
    }

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): AssignmentViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_admin_assignment, parent, false)
        return AssignmentViewHolder(view)
    }

    override fun onBindViewHolder(holder: AssignmentViewHolder, position: Int) {
        val item = items[position]

        holder.adminNameText.text = item.fullName
        holder.adminLoginText.text = item.login
        holder.carWashNameText.text = item.carWashName
        holder.carWashAddressText.text = item.carWashAddress
    }

    override fun getItemCount(): Int = items.size

    class AssignmentViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        val adminNameText: TextView = itemView.findViewById(R.id.adminNameText)
        val adminLoginText: TextView = itemView.findViewById(R.id.adminLoginText)
        val carWashNameText: TextView = itemView.findViewById(R.id.carWashNameText)
        val carWashAddressText: TextView = itemView.findViewById(R.id.carWashAddressText)
    }
}
