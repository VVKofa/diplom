package com.example.directionprogramm

import android.app.DatePickerDialog
import android.content.Intent
import android.graphics.Color
import android.os.Bundle
import android.view.View
import android.view.ViewGroup
import android.widget.Button
import android.widget.EditText
import android.widget.ImageButton
import android.widget.LinearLayout
import android.widget.TextView
import androidx.appcompat.app.AppCompatActivity
import androidx.cardview.widget.CardView
import androidx.lifecycle.lifecycleScope
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import kotlinx.coroutines.launch
import java.text.SimpleDateFormat
import java.util.Calendar
import java.util.Locale

class ManagerCarWashOrderHistoryActivity : AppCompatActivity() {

    private lateinit var backButton: ImageButton
    private lateinit var titleText: TextView
    private lateinit var ordersRecycler: RecyclerView
    private lateinit var emptyText: TextView

    private lateinit var filterButton: ImageButton
    private lateinit var filterLayout: LinearLayout
    private lateinit var startDateInput: EditText
    private lateinit var endDateInput: EditText
    private lateinit var startCalendarButton: Button
    private lateinit var endCalendarButton: Button
    private lateinit var applyDateFilterButton: Button
    private lateinit var clearDateFilterButton: Button

    private lateinit var db: AppDatabase
    private lateinit var sessionManager: SessionManager
    private lateinit var requestRepository: RequestRepository
    private lateinit var adapter: AdminRequestsHistoryAdapter

    private val carWashMap = mutableMapOf<Int, CarWashEntity>()
    private var selectedDistrict: String = ""

    private var startDateMillis: Long? = null
    private var endDateMillis: Long? = null

    private val dateFormat = SimpleDateFormat("dd.MM.yyyy", Locale.getDefault())

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_manager_carwash_order_history)

        selectedDistrict = intent.getStringExtra("district") ?: ""

        db = AppDatabase.getDatabase(this)
        sessionManager = SessionManager(this)
        requestRepository = RequestRepository(this)

        backButton = findViewById(R.id.backButtonCarWashOrderHistory)
        titleText = findViewById(R.id.carWashOrdersTitle)
        ordersRecycler = findViewById(R.id.carWashOrdersRecycler)
        emptyText = findViewById(R.id.emptyCarWashOrdersText)

        filterButton = findViewById(R.id.filterButton)
        filterLayout = findViewById(R.id.filterLayout)
        startDateInput = findViewById(R.id.startDateInput)
        endDateInput = findViewById(R.id.endDateInput)
        startCalendarButton = findViewById(R.id.startCalendarButton)
        endCalendarButton = findViewById(R.id.endCalendarButton)
        applyDateFilterButton = findViewById(R.id.applyDateFilterButton)
        clearDateFilterButton = findViewById(R.id.clearDateFilterButton)

        titleText.text = if (selectedDistrict.isNotEmpty()) {
            "Заявки: $selectedDistrict"
        } else {
            "Заявки с автомоек"
        }

        backButton.setOnClickListener {
            finish()
        }

        filterButton.setOnClickListener {
            filterLayout.visibility =
                if (filterLayout.visibility == View.GONE) View.VISIBLE else View.GONE
        }

        startCalendarButton.setOnClickListener {
            showDatePicker(isStartDate = true)
        }

        endCalendarButton.setOnClickListener {
            showDatePicker(isStartDate = false)
        }

        applyDateFilterButton.setOnClickListener {
            applyDateFilterFromInputs()
        }

        clearDateFilterButton.setOnClickListener {
            startDateMillis = null
            endDateMillis = null
            startDateInput.setText("")
            endDateInput.setText("")
            loadAdminRequestsHistory()
        }

        ordersRecycler.layoutManager = LinearLayoutManager(this)

        adapter = AdminRequestsHistoryAdapter { request ->
            val intent = Intent(this, ManagerRequestDetailsActivity::class.java)
            intent.putExtra("request_id", request.id)
            startActivity(intent)
        }

        ordersRecycler.adapter = adapter

        loadAdminRequestsHistory()
    }

    override fun onResume() {
        super.onResume()
        loadAdminRequestsHistory()
    }

    private fun loadAdminRequestsHistory() {
        val managerName = sessionManager.getUserName()

        if (managerName.isNullOrEmpty()) {
            emptyText.visibility = View.VISIBLE
            ordersRecycler.visibility = View.GONE
            emptyText.text = "Пользователь не найден"
            return
        }

        lifecycleScope.launch {
            val managerCarWashes = db.carWashDao()
                .getCarWashesByManager(managerName)
                .filter { selectedDistrict.isEmpty() || it.district == selectedDistrict }

            val managerCarWashIds = managerCarWashes.map { it.id }

            carWashMap.clear()
            managerCarWashes.forEach { carWash ->
                carWashMap[carWash.id] = carWash
            }

            val requests = requestRepository.getAdminRequests()
                .filter { managerCarWashIds.contains(it.carWashId) }
                .filter { request ->
                    val requestDate = runCatching {
                        dateFormat.parse(request.createdDate)?.time
                    }.getOrNull()

                    if (requestDate == null) {
                        true
                    } else {
                        val afterStart = startDateMillis?.let { requestDate >= it } ?: true
                        val beforeEnd = endDateMillis?.let { requestDate <= it } ?: true
                        afterStart && beforeEnd
                    }
                }
                .sortedByDescending { it.id }

            if (requests.isEmpty()) {
                emptyText.visibility = View.VISIBLE
                ordersRecycler.visibility = View.GONE
                emptyText.text = "Заявок за выбранный период нет"
            } else {
                emptyText.visibility = View.GONE
                ordersRecycler.visibility = View.VISIBLE
                adapter.submitList(requests)
            }
        }
    }

    private fun applyDateFilterFromInputs() {
        val startText = startDateInput.text.toString().trim()
        val endText = endDateInput.text.toString().trim()

        startDateMillis = if (startText.isNotEmpty()) {
            runCatching {
                val date = dateFormat.parse(startText)
                Calendar.getInstance().apply {
                    time = date!!
                    set(Calendar.HOUR_OF_DAY, 0)
                    set(Calendar.MINUTE, 0)
                    set(Calendar.SECOND, 0)
                    set(Calendar.MILLISECOND, 0)
                }.timeInMillis
            }.getOrNull()
        } else {
            null
        }

        endDateMillis = if (endText.isNotEmpty()) {
            runCatching {
                val date = dateFormat.parse(endText)
                Calendar.getInstance().apply {
                    time = date!!
                    set(Calendar.HOUR_OF_DAY, 23)
                    set(Calendar.MINUTE, 59)
                    set(Calendar.SECOND, 59)
                    set(Calendar.MILLISECOND, 999)
                }.timeInMillis
            }.getOrNull()
        } else {
            null
        }

        loadAdminRequestsHistory()
    }

    private fun showDatePicker(isStartDate: Boolean) {
        val calendar = Calendar.getInstance()

        DatePickerDialog(
            this,
            { _, year, month, day ->
                val selectedCalendar = Calendar.getInstance().apply {
                    set(Calendar.YEAR, year)
                    set(Calendar.MONTH, month)
                    set(Calendar.DAY_OF_MONTH, day)

                    if (isStartDate) {
                        set(Calendar.HOUR_OF_DAY, 0)
                        set(Calendar.MINUTE, 0)
                        set(Calendar.SECOND, 0)
                        set(Calendar.MILLISECOND, 0)
                    } else {
                        set(Calendar.HOUR_OF_DAY, 23)
                        set(Calendar.MINUTE, 59)
                        set(Calendar.SECOND, 59)
                        set(Calendar.MILLISECOND, 999)
                    }
                }

                val formattedDate = dateFormat.format(selectedCalendar.time)

                if (isStartDate) {
                    startDateMillis = selectedCalendar.timeInMillis
                    startDateInput.setText(formattedDate)
                } else {
                    endDateMillis = selectedCalendar.timeInMillis
                    endDateInput.setText(formattedDate)
                }

                loadAdminRequestsHistory()
            },
            calendar.get(Calendar.YEAR),
            calendar.get(Calendar.MONTH),
            calendar.get(Calendar.DAY_OF_MONTH)
        ).show()
    }

    inner class AdminRequestsHistoryAdapter(
        private val onClick: (RequestModel) -> Unit
    ) : RecyclerView.Adapter<AdminRequestsHistoryAdapter.RequestViewHolder>() {

        private val items = mutableListOf<RequestModel>()

        fun submitList(newItems: List<RequestModel>) {
            items.clear()
            items.addAll(newItems)
            notifyDataSetChanged()
        }

        override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): RequestViewHolder {
            val card = CardView(parent.context).apply {
                radius = 20f
                cardElevation = 6f
                useCompatPadding = true
                setCardBackgroundColor(Color.WHITE)
                layoutParams = RecyclerView.LayoutParams(
                    RecyclerView.LayoutParams.MATCH_PARENT,
                    RecyclerView.LayoutParams.WRAP_CONTENT
                ).apply {
                    leftMargin = 12
                    rightMargin = 12
                    topMargin = 8
                    bottomMargin = 8
                }
            }

            val container = LinearLayout(parent.context).apply {
                orientation = LinearLayout.VERTICAL
                setPadding(28, 24, 28, 24)
            }

            val title = TextView(parent.context).apply {
                textSize = 19f
                setTextColor(Color.parseColor("#1F2937"))
                setTypeface(typeface, android.graphics.Typeface.BOLD)
            }

            val date = TextView(parent.context).apply {
                textSize = 15f
                setTextColor(Color.parseColor("#374151"))
                setPadding(0, 8, 0, 0)
            }

            val count = TextView(parent.context).apply {
                textSize = 15f
                setTextColor(Color.parseColor("#374151"))
                setPadding(0, 6, 0, 0)
            }

            val district = TextView(parent.context).apply {
                textSize = 14f
                setTextColor(Color.parseColor("#2563EB"))
                setPadding(0, 8, 0, 0)
                setTypeface(typeface, android.graphics.Typeface.BOLD)
            }

            val address = TextView(parent.context).apply {
                textSize = 14f
                setTextColor(Color.parseColor("#6B7280"))
                setPadding(0, 6, 0, 0)
            }

            val status = TextView(parent.context).apply {
                textSize = 15f
                setPadding(0, 8, 0, 0)
                setTypeface(typeface, android.graphics.Typeface.BOLD)
            }

            container.addView(title)
            container.addView(date)
            container.addView(count)
            container.addView(district)
            container.addView(address)
            container.addView(status)

            card.addView(container)

            return RequestViewHolder(card, title, date, count, district, address, status)
        }

        override fun onBindViewHolder(holder: RequestViewHolder, position: Int) {
            val request = items[position]
            val carWash = carWashMap[request.carWashId]

            holder.title.text = "Заявка №${request.id}"
            holder.date.text = "Дата создания: ${request.createdDate}"
            holder.count.text = "Товаров: ${request.items.sumOf { it.quantity }}"
            holder.district.text = "Округ: ${carWash?.district ?: "—"}"
            holder.address.text = "Автомойка: ${carWash?.address ?: "не найдена"}"
            holder.status.text = "Статус: ${request.status}"

            holder.status.setTextColor(
                when (request.status) {
                    "Новая" -> Color.parseColor("#10B981")
                    "Обработана" -> Color.parseColor("#2563EB")
                    "Отклонена" -> Color.parseColor("#EF4444")
                    else -> Color.parseColor("#374151")
                }
            )

            holder.itemView.setOnClickListener {
                onClick(request)
            }
        }

        override fun getItemCount(): Int = items.size

        inner class RequestViewHolder(
            itemView: View,
            val title: TextView,
            val date: TextView,
            val count: TextView,
            val district: TextView,
            val address: TextView,
            val status: TextView
        ) : RecyclerView.ViewHolder(itemView)
    }
}
